// width based on hover
.pathfinder--is_collapsed
	width: 10px !important
	transition: width 0.1s ease
	box-shadow: inset -2px 0 0 rgba(0, 0, 0, .28) !important

.pathfinder--is_collapsed:hover,
.main-layout__navigation:hover
	width: 48px !important
	transition: width 0.1s ease
	box-shadow: none !important

.pathfinder-tray-expander[data-better-aa-disabled-expander='true']
	cursor: not-allowed !important
	opacity: .48 !important
	filter: grayscale(1) !important

	.pathfinder-tray-expander__icon-circle,
	.pathfinder-tray-expander__icon-path
		fill: #B8B8B8 !important
		stroke: #8A8A8A !important
