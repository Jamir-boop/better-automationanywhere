// Grab cursor style
.editor-palette-item__child--is_draggable
	cursor: pointer !important
.editor-palette-item__child--is_draggable:active
	cursor: url('data:image/png;base64,') 10 10, grab !important

button[data-pendo-stashed-aria-label="Open Resource Center"]
	display: none !important

.editor-init-form-property .editor-init-form-property__path-field .command-button
	position: relative

// Close button change the white bg to the same of run button
button[name="close"]
.command-button
	background: transparent !important
	&:hover
		background: var(--color_background_interactive_whisper_hover) !important

.loadable__overlay
	customGradientBackground()

// Input text as text areas
.textinput-cell-input-content[role="textbox"][type="content"]
	max-height: 400px !important
	overflow: auto !important
	word-wrap: break-word !important
	white-space: pre-wrap !important

.better-aa-variable-metadata-row
	.editor-palette-item__child-label
		white-space: nowrap !important
		line-height: 1.3
		overflow: visible
		text-overflow: clip

	.editor-palette-item__child-label .clipped-text__string--for_presentation
		white-space: nowrap !important
