@import 'modern-normalize/modern-normalize.css'

:root
	--bg: #000000
	--surface-0: #000000
	--surface-1: #050505
	--surface-2: #080808
	--surface-3: #101010
	--text: #FFFFFF
	--text-muted: #A0A0A0
	--text-disabled: #555555
	--text-on-accent: #000000
	--accent: #FFB900
	--accent-hover: #FFB900
	--accent-active: #FFB900
	--accent-outline: #FFB900
	--border: #332500
	--border-strong: #664A00
	font-family: Cascadia Code NF, Segoe UI, sans-serif
	line-height: 1.5
	font-weight: 400
	color: var(--text)
	background: var(--bg)
	font-synthesis: none
	text-rendering: optimizeLegibility
	-webkit-font-smoothing: antialiased
	-moz-osx-font-smoothing: grayscale

body
	margin: 0
	min-width: 300px
	color: var(--text)
	background: var(--bg)

button,
select,
input,
textarea
	font: inherit

#app
	display: flex
	flex-direction: column
	gap: 12px
	min-height: 100vh
	padding: 14px

.panel-header
	display: flex
	align-items: center
	justify-content: space-between
	gap: 12px

	h1
		margin: 0
		font-size: 1.08rem
		line-height: 1.2

	p
		margin: 3px 0 0
		color: var(--text-muted)
		font-size: .76rem

.tab-list
	display: grid
	grid-template-columns: repeat(4, 1fr)
	gap: 4px
	padding: 3px
	border: 1px solid var(--border)
	border-radius: 8px
	background: var(--surface-2)

.tab-button
	min-height: 34px
	padding: 6px 8px
	color: var(--text)
	background: transparent
	border: 0
	border-radius: 6px
	cursor: pointer

	&:hover
		color: var(--text-on-accent)
		background: var(--accent-hover)

	&.is-active
		color: var(--text-on-accent)
		background: var(--accent-active)
		font-weight: 700

main
	display: flex
	flex-direction: column
	gap: 12px

.tab-panel
	display: flex
	flex-direction: column
	gap: 12px

	&[hidden]
		display: none

.panel-section
	display: flex
	flex-direction: column
	gap: 10px
	border: 1px solid var(--border)
	border-radius: 8px
	padding: 12px
	background: var(--surface-2)

	h2
		margin: 0
		font-size: .82rem
		text-transform: uppercase
		color: var(--accent)

.section-heading-row
	display: flex
	align-items: center
	justify-content: space-between
	gap: 10px

	h2
		flex: 1 1 auto

	#restoreUserstyleDefaults
		flex: 0 0 auto
		font-size: .72rem

.style-feature-group
	display: flex
	flex-direction: column
	gap: 8px
	padding-top: 2px

	& + &
		margin-top: 6px
		padding-top: 10px
		border-top: 1px solid var(--border)

	h3
		margin: 0
		color: var(--text-muted)
		font-size: .74rem
		text-transform: uppercase

.setting-row,
.select-row,
.slot-row,
.text-row,
.color-row,
.info-row
	display: flex
	align-items: center
	justify-content: space-between
	gap: 12px

	strong
		display: block
		font-size: .86rem

	small
		display: block
		color: var(--text-muted)
		font-size: .7rem

.text-row
	align-items: stretch
	flex-direction: column
	gap: 6px

.color-row
	align-items: stretch
	flex-direction: column
	gap: 8px

.color-controls
	display: grid
	grid-template-columns: 42px minmax(90px, 1fr) 42px
	gap: 8px
	align-items: center

.upload-row
	display: grid
	grid-template-columns: minmax(0, 1fr) auto
	gap: 8px
	align-items: center

.background-preview
	width: 100%
	min-height: 112px
	border: 1px solid var(--border-strong)
	border-radius: 6px
	background-color: var(--surface-0)
	background-position: center
	background-repeat: no-repeat

input[type='checkbox']
	width: 36px
	height: 20px
	accent-color: var(--accent)

select,
input[type='text'],
input[type='file'],
textarea
	width: 100%
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border-strong)
	border-radius: 6px
	padding: 7px 8px

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px
		border-color: var(--accent-outline)

select
	max-width: 118px

input[type='color']
	width: 42px
	height: 32px
	padding: 2px
	background: var(--surface-0)
	border: 1px solid var(--border-strong)
	border-radius: 6px

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

input[type='range']
	width: 100%
	accent-color: var(--accent)

input[type='file']::file-selector-button
	color: var(--text-on-accent)
	background: var(--accent)
	border: 1px solid var(--accent)
	border-radius: 4px
	padding: 4px 7px
	cursor: pointer

output
	color: var(--text-muted)
	font-size: .72rem
	text-align: right

textarea
	resize: vertical
	min-height: 72px
	font-family: Cascadia Code NF, Consolas, monospace
	font-size: .78rem
	line-height: 1.35

.json-area
	min-height: 180px

.json-field
	position: relative

	.json-area
		padding-right: 38px

.clear-json-button
	position: absolute
	top: 6px
	right: 6px
	display: inline-flex
	align-items: center
	justify-content: center
	width: 26px
	height: 26px
	padding: 0
	color: var(--accent)
	background: var(--surface-0)
	border-color: var(--border-strong)

	&[hidden]
		display: none

	svg
		width: 15px
		height: 15px
		fill: none
		stroke: currentColor
		stroke-width: 2
		stroke-linecap: round
		stroke-linejoin: round

.button-grid
	display: grid
	grid-template-columns: 1fr 1fr
	gap: 8px

button
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border-strong)
	border-radius: 6px
	padding: 7px 8px
	cursor: pointer

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

	&:hover
		color: var(--text-on-accent)
		background: var(--accent-hover)
		border-color: var(--accent-hover)

		svg,
		svg *
			fill: currentColor
			stroke: currentColor

	&:disabled
		color: var(--text-disabled)
		background: var(--surface-1)
		border-color: var(--border)
		cursor: not-allowed

.userstyle-dependent.is-disabled
	opacity: .52

	input,
	select,
	textarea,
	button
		cursor: not-allowed

	input[type='file']::file-selector-button
		color: var(--text-disabled)
		background: var(--surface-1)
		border-color: var(--border)
		cursor: not-allowed

.slots
	display: flex
	flex-direction: column
	gap: 8px

.slot-row
	display: grid
	grid-template-columns: minmax(60px, .8fr) minmax(104px, 1fr) 58px 58px
	align-items: center
	gap: 6px
	padding: 6px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-1)
	cursor: pointer

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

	&.is-populated
		border-color: var(--border-strong)

	&.is-invalid
		border-color: #A33A3A

	span
		color: var(--text)
		font-size: .82rem

	button
		padding-right: 6px
		padding-left: 6px

.slot-state
	color: var(--text-muted) !important
	font-size: .68rem !important
	overflow: hidden
	text-overflow: ellipsis
	white-space: nowrap

.slot-row.is-populated .slot-state
	color: var(--accent) !important

.slot-row.is-invalid .slot-state
	color: #FF8A8A !important

.action-summary
	margin: 0
	padding: 8px
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border)
	border-radius: 6px
	font-family: Cascadia Code NF, Consolas, monospace
	font-size: .72rem
	line-height: 1.35
	white-space: pre-wrap
	overflow-wrap: anywhere

	&[hidden]
		display: none

.feedback-section
	#clearFeedback
		flex: 0 0 auto
		font-size: .72rem

.feedback-list
	display: flex
	flex-direction: column
	gap: 6px
	max-height: 220px
	overflow: auto

.feedback-empty
	margin: 0
	color: var(--text-muted)
	font-size: .74rem

.feedback-line
	display: flex
	flex-direction: column
	gap: 3px
	padding: 7px 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)

	small
		color: var(--text-muted)
		font-size: .62rem
		text-transform: uppercase

	span
		color: var(--text)
		font-size: .72rem
		line-height: 1.32

	pre
		margin: 2px 0 0
		padding: 6px
		color: var(--text-muted)
		background: var(--surface-1)
		border: 1px solid var(--border)
		border-radius: 4px
		font-size: .66rem
		white-space: pre-wrap
		overflow-wrap: anywhere

.feedback-info
	border-color: var(--border)

.feedback-warn
	border-color: var(--accent)

.feedback-error
	border-color: #A33A3A

.info-panel
	align-items: flex-start

.info-row
	width: 100%
	color: var(--text-muted)

	strong
		color: var(--text)

.github-link
	display: inline-flex
	align-items: center
	justify-content: center
	width: 26px
	height: 26px
	color: var(--accent)
	border: 1px solid var(--border-strong)
	border-radius: 6px
	background: var(--surface-0)

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

	&:hover
		color: var(--text-on-accent)
		background: var(--accent-hover)
		border-color: var(--accent-hover)

	svg
		width: 16px
		height: 16px
		fill: currentColor

.help-content
	width: 100%
	color: var(--text)
	font-size: .76rem
	line-height: 1.38

	h3,
	h4
		margin: 12px 0 6px
		color: var(--accent)
		font-size: .78rem
		text-transform: uppercase

	h3:first-child
		margin-top: 4px

	ul
		margin: 0 0 8px
		padding-left: 18px

	li
		margin-bottom: 5px
		color: var(--text-muted)

	b
		color: var(--text)

	code
		color: var(--accent)
		background: var(--surface-0)
		border: 1px solid var(--border)
		border-radius: 4px
		padding: 1px 4px

.tools-context
	margin: 0
	color: var(--text-muted)
	font-size: .76rem
	line-height: 1.35
	overflow-wrap: anywhere

.tool-action-grid
	display: grid
	grid-template-columns: repeat(2, minmax(0, 1fr))
	gap: 8px

	.tool-action-button.is-active
		color: var(--text-on-accent)
		background: var(--accent-active)
		border-color: var(--accent-active)
		font-weight: 700

.tools-count
	color: var(--text-muted)
	font-size: .72rem
	white-space: nowrap

.tools-list-toolbar
	display: grid
	grid-template-columns: minmax(0, 1fr) auto
	gap: 8px
	align-items: center

.tools-select-all
	display: flex
	align-items: center
	gap: 6px
	color: var(--text-muted)
	font-size: .72rem
	white-space: nowrap

	input
		width: 18px
		height: 18px

.tools-file-list
	display: flex
	flex-direction: column
	gap: 6px
	max-height: 360px
	overflow: auto

.tool-file-row
	display: grid
	grid-template-columns: 22px minmax(0, 1fr)
	gap: 8px
	align-items: start
	padding: 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-1)
	cursor: pointer

	&:hover
		border-color: var(--border-strong)

	input
		width: 18px
		height: 18px
		margin-top: 2px

.tool-file-text
	display: flex
	min-width: 0
	flex-direction: column
	gap: 2px

	strong
		font-size: .78rem
		line-height: 1.3
		overflow-wrap: anywhere

	small
		color: var(--text-muted)
		font-size: .66rem
		line-height: 1.3
		overflow-wrap: anywhere

.tools-empty
	margin: 0
	color: var(--text-muted)
	font-size: .74rem

.tools-action-bar
	display: grid
	grid-template-columns: 1fr 1fr
	gap: 8px

	button[hidden]
		display: none

.tools-results
	margin: 0
	padding: 8px
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border)
	border-radius: 6px
	font-family: Cascadia Code NF, Consolas, monospace
	font-size: .7rem
	line-height: 1.35
	white-space: pre-wrap
	overflow-wrap: anywhere
	max-height: 260px
	overflow: auto

.tools-json-area
	min-height: 320px

#status
	min-height: 18px
	margin: 0
	color: var(--accent)
	font-size: .76rem

	&[data-severity='error']
		color: #FF8A8A

	&[data-severity='warn']
		color: var(--accent)
