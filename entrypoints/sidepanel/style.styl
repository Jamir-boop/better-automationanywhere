:root
	--bg: #000000
	--surface-0: #000000
	--surface-1: #050505
	--surface-2: #080808
	--surface-3: #101010
	--text: #FFFFFF
	--text-muted: #A0A0A0
	--text-disabled: #555555
	--text-on-accent: #000000
	--accent: #FFB900
	--accent-hover: #FFB900
	--accent-active: #FFB900
	--accent-outline: #FFB900
	--border: #332500
	--border-strong: #664A00
	font-family: Cascadia Code NF, Segoe UI, sans-serif
	line-height: 1.5
	font-weight: 400
	color: var(--text)
	background: var(--bg)
	font-synthesis: none
	text-rendering: optimizeLegibility
	-webkit-font-smoothing: antialiased
	-moz-osx-font-smoothing: grayscale

html
	scrollbar-gutter: stable

@supports not (scrollbar-gutter: stable)
	html
		overflow-y: scroll

*,
*::before,
*::after
	box-sizing: border-box

body
	margin: 0
	min-width: 300px
	color: var(--text)
	background: var(--bg)

::selection
	color: #000000 !important
	background: var(--accent) !important

::-moz-selection
	color: #000000 !important
	background: var(--accent) !important

[hidden]
	display: none !important

button,
select,
input,
textarea
	font: inherit
	min-width: 0

#app
	display: flex
	flex-direction: column
	gap: 12px
	min-height: 100vh
	min-width: 0
	padding: 14px

.panel-header
	display: flex
	align-items: center
	justify-content: space-between
	gap: 12px

	> div
		min-width: 0

	h1
		margin: 0
		font-size: 1.08rem
		line-height: 1.2
		overflow-wrap: anywhere

	p
		margin: 3px 0 0
		color: var(--text-muted)
		font-size: .76rem

.header-controls
	display: flex
	align-items: center
	gap: 10px
	flex-wrap: wrap
	justify-content: flex-end

.version-chip
	color: var(--accent)
	font-size: .76rem
	font-weight: 700

.debug-toggle
	display: flex
	align-items: center
	gap: 6px
	color: var(--text-muted)
	font-size: .72rem
	white-space: nowrap

	input
		width: 34px
		height: 18px

.tab-list,
.health-subtabs
	display: grid
	grid-template-columns: repeat(3, minmax(0, 1fr))
	gap: 4px
	padding: 3px
	border: 1px solid var(--border)
	border-radius: 8px
	background: var(--surface-2)

	&.has-health-tab
		grid-template-columns: minmax(0, 3fr) minmax(0, 3fr) minmax(0, 3fr) minmax(0, 1fr)

.health-subtabs
	display: flex
	grid-template-columns: unset

.tab-button,
.health-subtab
	min-width: 0
	min-height: 34px
	padding: 6px 8px
	color: var(--text)
	background: transparent
	border: 0
	border-radius: 6px
	cursor: pointer
	overflow: hidden
	text-overflow: ellipsis
	white-space: nowrap

	&:hover
		color: var(--text-on-accent)
		background: var(--accent-hover)

	&.is-active
		outline: 1px solid var(--accent-active)
		outline-offset: -1px

.health-subtab
	flex: 1
	min-height: 30px
	font-size: .74rem

.tab-button-health
	font-size: 1rem
	line-height: 1

main
	display: flex
	flex-direction: column
	gap: 12px
	min-width: 0

.tab-panel
	display: flex
	flex-direction: column
	gap: 12px
	min-width: 0

	&[hidden]
		display: none

.panel-section
	display: flex
	flex-direction: column
	gap: 10px
	min-width: 0
	border: 1px solid var(--border)
	border-radius: 8px
	padding: 12px
	background: var(--surface-2)

	h2
		margin: 0
		font-size: .82rem
		text-transform: uppercase
		color: var(--accent)

.section-heading-row
	display: flex
	align-items: center
	justify-content: space-between
	gap: 10px
	min-width: 0

	h2
		flex: 1 1 auto
		min-width: 0

	#restoreUserstyleDefaults
		flex: 0 0 auto
		font-size: .72rem

.section-heading-actions
	display: inline-flex
	align-items: center
	gap: 8px
	flex: 0 0 auto
	min-width: 0

.collapsible-section-heading
	button
		flex: 0 0 auto

.collapsible-toggle
	position: relative
	display: inline-flex
	align-items: center
	justify-content: center
	width: 28px
	height: 28px
	padding: 0
	font-size: 0
	line-height: 0

	&::before
		content: '+'
		color: currentColor
		font-size: 1rem
		font-weight: 800
		line-height: 1

	&[aria-expanded='true']::before
		content: '-'

.collapsible-section-content
	display: flex
	flex-direction: column
	gap: 8px

	&[hidden]
		display: none

.taskbot-json-content
	display: flex
	flex-direction: column
	gap: 8px
	min-width: 0

.inline-hint
	margin: -2px 0 0
	color: var(--text-muted)
	font-size: .68rem
	line-height: 1.28
	overflow-wrap: anywhere

.style-feature-group
	display: flex
	flex-direction: column
	gap: 8px
	padding-top: 2px

	& + &
		margin-top: 6px
		padding-top: 10px
		border-top: 1px solid var(--border)

	h3
		margin: 0
		color: var(--text-muted)
		font-size: .74rem
		text-transform: uppercase

.control-room-status
	display: flex
	flex-direction: column
	gap: 8px
	padding: 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-1)

.control-room-head
	display: flex
	align-items: center
	justify-content: space-between
	gap: 8px

	strong
		display: block
		font-size: .82rem

	small
		display: block
		color: var(--text-muted)
		font-size: .68rem

	button
		flex: 0 0 auto
		padding: 4px 7px
		font-size: .68rem

.control-room-meta,
.control-room-alert
	margin: 0
	color: var(--text-muted)
	font-size: .68rem
	line-height: 1.3
	overflow-wrap: anywhere

.control-room-alert
	color: #FFD45A

.force-control-room-row
	padding-top: 6px
	border-top: 1px solid var(--border)

.setting-row,
.select-row,
.slot-row,
.text-row,
.color-row,
.info-row
	display: flex
	align-items: center
	justify-content: space-between
	gap: 12px

	strong
		display: block
		font-size: .86rem

	small
		display: block
		color: var(--text-muted)
		font-size: .7rem

	> span
		min-width: 0
		overflow-wrap: anywhere

.text-row
	align-items: stretch
	flex-direction: column
	gap: 6px

.color-row
	align-items: stretch
	flex-direction: column
	gap: 8px

.bot-modal-position-dependent
	margin-top: -4px
	padding-left: 10px
	border-left: 1px solid var(--border)

.style-subsetting
	margin-top: -4px
	padding-left: 10px
	border-left: 1px solid var(--border)

.color-controls
	display: grid
	grid-template-columns: 42px minmax(90px, 1fr) 42px
	gap: 8px
	align-items: center

.upload-row
	display: grid
	grid-template-columns: minmax(0, 1fr) auto
	gap: 8px
	align-items: center
	min-width: 0

.background-preview
	width: 100%
	min-height: 112px
	border: 1px solid var(--border-strong)
	border-radius: 6px
	background-color: var(--surface-0)
	background-position: center
	background-repeat: no-repeat

input[type='checkbox']
	width: 36px
	height: 20px
	accent-color: var(--accent)

select,
input[type='text'],
input[type='search'],
input[type='file'],
textarea
	width: 100%
	max-width: 100%
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border-strong)
	border-radius: 6px
	padding: 7px 8px

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px
		border-color: var(--accent-outline)

select
	max-width: 118px

.shortcut-select
	max-width: 176px

input[type='color']
	width: 42px
	height: 32px
	padding: 2px
	background: var(--surface-0)
	border: 1px solid var(--border-strong)
	border-radius: 6px

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

input[type='range']
	width: 100%
	accent-color: var(--accent)

input[type='file']::file-selector-button
	color: var(--text-on-accent)
	background: var(--accent)
	border: 1px solid var(--accent)
	border-radius: 4px
	padding: 4px 7px
	cursor: pointer

output
	color: var(--text-muted)
	font-size: .72rem
	text-align: right

textarea
	resize: vertical
	min-height: 72px
	font-family: Cascadia Code NF, Consolas, monospace
	font-size: .78rem
	line-height: 1.35

	&.is-invalid
		border-color: #A33A3A

		&:focus
			outline-color: #A33A3A
			border-color: #A33A3A

.json-area
	min-height: 180px

.json-inline-error
	margin: -4px 0 0
	color: #FF8A8A
	font-size: .72rem
	line-height: 1.3

.json-workbench-tools
	display: flex
	flex-direction: column
	gap: 8px

	select
		max-width: 100%

.json-workbench-fields
	display: grid
	grid-template-columns: repeat(2, minmax(0, 1fr))
	gap: 8px

	label
		display: flex
		flex-direction: column
		gap: 4px
		min-width: 0
		color: var(--text-muted)
		font-size: .68rem
		text-transform: uppercase

.json-workbench-checkbox
	display: inline-flex
	align-items: center
	gap: 6px
	color: var(--text-muted)
	font-size: .72rem
	white-space: nowrap

	input
		width: 18px
		height: 18px

.json-workbench-actions
	button
		min-width: 0
		white-space: normal

.json-field
	position: relative
	min-width: 0

	.json-area
		padding-right: 38px

.clear-json-button
	position: absolute
	top: 6px
	right: 6px
	display: inline-flex
	align-items: center
	justify-content: center
	width: 26px
	height: 26px
	padding: 0
	color: var(--accent)
	background: var(--surface-0)
	border-color: var(--border-strong)

	&[hidden]
		display: none

	svg
		width: 15px
		height: 15px
		fill: none
		stroke: currentColor
		stroke-width: 2
		stroke-linecap: round
		stroke-linejoin: round

.button-grid
	display: grid
	grid-template-columns: repeat(2, minmax(0, 1fr))
	gap: 8px

.button-grid-full
	grid-column: 1 / -1

button
	min-width: 0
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border-strong)
	border-radius: 6px
	padding: 7px 8px
	text-align: center
	cursor: pointer

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

	&:hover
		color: var(--text-on-accent)
		background: var(--accent-hover)
		border-color: var(--accent-hover)

		svg,
		svg *
			fill: currentColor
			stroke: currentColor

	&:disabled
		color: var(--text-disabled)
		background: var(--surface-1)
		border-color: var(--border)
		cursor: not-allowed

.userstyle-dependent.is-disabled
	opacity: .52

	input,
	select,
	textarea,
	button
		cursor: not-allowed

	input[type='file']::file-selector-button
		color: var(--text-disabled)
		background: var(--surface-1)
		border-color: var(--border)
		cursor: not-allowed

.slots
	display: flex
	flex-direction: column
	gap: 8px

.slot-row
	display: grid
	grid-template-columns: minmax(44px, .75fr) minmax(0, 1fr) auto auto
	align-items: center
	gap: 6px
	padding: 6px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-1)
	cursor: pointer

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

	&.is-populated
		border-color: var(--border-strong)

	&.is-invalid
		border-color: #A33A3A

	span
		min-width: 0
		color: var(--text)
		font-size: .82rem

	button
		padding-right: 6px
		padding-left: 6px

.slot-state
	color: var(--text-muted) !important
	font-size: .68rem !important
	overflow: hidden
	text-overflow: ellipsis
	white-space: nowrap

.slot-row.is-populated .slot-state
	color: var(--accent) !important

.slot-row.is-invalid .slot-state
	color: #FF8A8A !important

.action-package-list,
.taskbot-package-list
	display: flex
	flex-direction: column
	gap: 10px
	margin: 0
	padding: 8px
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border)
	border-radius: 6px
	font-size: .72rem
	line-height: 1.35
	overflow-wrap: anywhere
	user-select: text
	cursor: text

	&[hidden]
		display: none

.json-info-tabs
	display: flex
	align-items: center
	gap: 12px
	flex-wrap: wrap
	min-width: 0
	padding-bottom: 6px
	border-bottom: 1px solid var(--border)

.json-info-tab
	display: inline-flex
	align-items: center
	gap: 5px
	min-height: 24px
	padding: 0 0 4px
	color: var(--text-muted)
	background: transparent
	border: 0
	border-bottom: 2px solid transparent
	border-radius: 0
	font-size: .68rem
	text-transform: uppercase
	cursor: pointer

	&:hover
		color: var(--text)
		background: transparent
		border-color: var(--border-strong)

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

	&.is-active
		color: var(--text)
		border-color: var(--accent)

.json-info-tab-count
	color: var(--accent)
	font-size: .78rem
	font-weight: 700
	text-transform: none

.json-info-list
	font-family: Cascadia Code NF, Consolas, monospace
	font-size: .7rem
	line-height: 1.35
	white-space: pre-wrap
	overflow-wrap: anywhere
	user-select: text
	cursor: text

.feedback-section
	gap: 3px
	padding: 12px

	h2
		font-size: .74rem

	.section-heading-row
		gap: 6px

	.feedback-actions
		display: inline-flex
		align-items: center
		gap: 4px
		flex: 0 0 auto

		button
			padding: 3px 6px
			font-size: .66rem

.feedback-list
	--feedback-row-height: 26px
	display: flex
	flex-direction: column
	gap: 3px
	max-height: calc(var(--feedback-row-height) * 25 + 12px)
	overflow: auto

.feedback-empty
	margin: 0
	color: var(--text-muted)
	font-size: .68rem

.feedback-line
	display: grid
	grid-template-columns: minmax(96px, .5fr) minmax(0, 1fr)
	align-items: center
	gap: 6px
	min-height: var(--feedback-row-height)
	padding: 2px 6px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)

	small
		color: var(--text-muted)
		font-size: .52rem
		text-transform: uppercase
		overflow: hidden
		text-overflow: ellipsis
		white-space: nowrap

	span
		color: var(--text)
		font-size: .68rem
		line-height: 1.18
		overflow: hidden
		text-overflow: ellipsis
		white-space: nowrap

.feedback-info
	border-color: var(--border)

.feedback-warn
	border-color: var(--accent)

.feedback-error
	border-color: #A33A3A

.feedback-summary
	display: contents
	cursor: pointer

.feedback-line details[open] .feedback-summary small,
.feedback-line details[open] .feedback-summary span
	color: var(--accent)

.feedback-details,
.doctor-check-details,
.build-candidate-snippet
	margin: 0
	padding: 6px 8px
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border)
	border-radius: 4px
	font-family: Cascadia Code NF, Consolas, monospace
	font-size: .62rem
	line-height: 1.3
	white-space: pre-wrap
	overflow-wrap: anywhere
	user-select: text
	cursor: text

.feedback-details
	grid-column: 1 / -1

.doctor-check-details
	border: 0
	border-top: 1px solid var(--border)
	border-radius: 0
	line-height: 1.4

.health-subpanel
	display: flex
	flex-direction: column
	gap: 12px

.doctor-view-pills
	display: flex
	gap: 4px
	flex-wrap: wrap

.doctor-pill
	min-width: 0
	padding: 4px 8px
	font-size: .72rem
	white-space: nowrap

.doctor-checklist
	display: flex
	flex-direction: column
	gap: 3px

.doctor-check-row
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)
	overflow: hidden

.doctor-check-summary
	display: flex
	align-items: center
	gap: 6px
	padding: 4px 8px
	cursor: pointer
	list-style: none

	&::-webkit-details-marker
		display: none

.doctor-check-icon
	width: 16px
	flex: 0 0 auto
	text-align: center
	font-size: .78rem

.doctor-check-label
	flex: 1 1 auto
	min-width: 0
	font-size: .74rem
	overflow: hidden
	text-overflow: ellipsis
	white-space: nowrap

.doctor-check-meta
	flex: 0 1 auto
	min-width: 0
	color: var(--text-muted)
	font-size: .62rem
	overflow: hidden
	text-overflow: ellipsis
	white-space: nowrap

.doctor-status-pass .doctor-check-icon
	color: #3AA35C

.doctor-status-fail .doctor-check-icon
	color: #FF8A8A

.doctor-status-warn .doctor-check-icon
	color: #FFD45A

.doctor-status-skip .doctor-check-icon
	color: var(--text-muted)

.doctor-delta-fixed
	border-color: #3AA35C

.doctor-delta-regressed
	border-color: #A33A3A

.doctor-transient-group
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-1)
	padding: 6px

	summary
		padding: 2px 4px
		font-size: .72rem
		color: var(--text-muted)
		cursor: pointer

.doctor-transient-list
	display: flex
	flex-direction: column
	gap: 3px
	margin-top: 4px

.doctor-actions
	display: flex
	align-items: center
	gap: 8px
	min-width: 0

.doctor-summary
	color: var(--text-muted)
	font-size: .68rem

.supported-builds-list
	display: flex
	flex-direction: column
	gap: 4px

.supported-build-row
	display: flex
	align-items: center
	justify-content: space-between
	gap: 8px
	padding: 4px 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)
	font-size: .74rem

	span:first-child
		min-width: 0
		overflow-wrap: anywhere

	&.is-current-match
		border-color: var(--accent)

.supported-build-marker
	color: var(--accent)
	font-size: .62rem
	font-weight: 700
	text-transform: uppercase

.build-candidate
	display: flex
	flex-direction: column
	gap: 6px
	padding: 8px
	border: 1px solid var(--accent)
	border-radius: 6px
	background: var(--surface-1)

	.inline-hint
		margin: 0

.info-panel
	align-items: flex-start

.info-row
	width: 100%
	color: var(--text-muted)

	strong
		color: var(--text)

.github-link
	display: inline-flex
	align-items: center
	justify-content: center
	width: 26px
	height: 26px
	color: var(--accent)
	border: 1px solid var(--border-strong)
	border-radius: 6px
	background: var(--surface-0)

	&:focus
		outline: 2px solid var(--accent-outline)
		outline-offset: 2px

	&:hover
		color: var(--text-on-accent)
		background: var(--accent-hover)
		border-color: var(--accent-hover)

	svg
		width: 16px
		height: 16px
		fill: currentColor

.help-content
	width: 100%
	color: var(--text)
	font-size: .76rem
	line-height: 1.38

	h3,
	h4
		margin: 12px 0 6px
		color: var(--accent)
		font-size: .78rem
		text-transform: uppercase

	h3:first-child
		margin-top: 4px

	ul
		margin: 0 0 8px
		padding-left: 18px

	li
		margin-bottom: 5px
		color: var(--text-muted)

	b
		color: var(--text)

	code
		color: var(--accent)
		background: var(--surface-0)
		border: 1px solid var(--border)
		border-radius: 4px
		padding: 1px 4px

.tools-context
	margin: 0
	color: var(--text-muted)
	font-size: .76rem
	line-height: 1.35
	overflow-wrap: anywhere

.tools-clipboard-status
	margin: -4px 0 0
	color: var(--accent)
	font-size: .72rem
	font-weight: 700
	line-height: 1.25

.tools-refresh-group
	display: inline-flex
	align-items: center
	gap: 8px

.tools-availability-dot
	display: inline-block
	width: 9px
	height: 9px
	border-radius: 999px
	background: #A33A3A

	&[data-available='true']
		background: #3AA35C

.icon-button
	display: inline-flex
	align-items: center
	justify-content: center
	width: 30px
	height: 30px
	padding: 0
	border-radius: 999px
	font-size: 1rem
	line-height: 1

.tools-refresh-button
	width: 34px
	height: 34px
	font-size: 1.22rem
	font-weight: 800

	span
		line-height: 1

	&[data-has-tools='false']
		color: var(--text-on-accent)
		background: var(--accent)
		border-color: var(--accent)

.tool-action-grid
	display: grid
	grid-template-columns: repeat(2, minmax(0, 1fr))
	gap: 8px

	.tool-action-button.is-active
		color: var(--text-on-accent)
		background: var(--accent-active)
		border-color: var(--accent-active)
		font-weight: 700

.tools-help-matrix
	display: block

	&[hidden]
		display: none

	dl
		margin: 0
		display: grid
		gap: 6px

	div
		padding: 6px 0
		border-top: 1px solid var(--border)

	dt
		color: var(--text)
		font-size: .74rem
		font-weight: 700
		line-height: 1.3

	dd
		margin: 2px 0 0
		color: var(--text-muted)
		font-size: .68rem
		line-height: 1.35
		overflow-wrap: anywhere

.tools-count
	color: var(--text-muted)
	font-size: .72rem
	white-space: nowrap

.tools-list-toolbar
	display: grid
	grid-template-columns: minmax(0, 1fr) auto
	gap: 8px
	align-items: center

.tools-select-all
	display: flex
	align-items: center
	gap: 6px
	color: var(--text-muted)
	font-size: .72rem
	white-space: nowrap

	input
		width: 18px
		height: 18px

.tools-file-list
	display: flex
	flex-direction: column
	gap: 6px
	max-height: 360px
	overflow: auto

.tool-file-row
	display: grid
	grid-template-columns: 22px minmax(0, 1fr)
	gap: 8px
	align-items: start
	padding: 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-1)
	cursor: pointer

	&:hover
		border-color: var(--border-strong)

	input
		width: 18px
		height: 18px
		margin-top: 2px

	&.is-current-taskbot
		display: block
		cursor: default

.tool-file-text
	display: flex
	min-width: 0
	flex-direction: column
	gap: 2px

	strong
		font-size: .78rem
		line-height: 1.3
		overflow-wrap: anywhere

	small
		color: var(--text-muted)
		font-size: .66rem
		line-height: 1.3
		overflow-wrap: anywhere

.tools-empty
	margin: 0
	color: var(--text-muted)
	font-size: .74rem

.tools-action-bar
	display: grid
	grid-template-columns: repeat(2, minmax(0, 1fr))
	gap: 8px

	button[hidden]
		display: none

.tools-export-format
	display: grid
	grid-template-columns: minmax(0, 1fr)
	gap: 6px
	padding: 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)

	&[hidden]
		display: none

.tools-export-format-label
	color: var(--accent)
	font-size: .74rem
	font-weight: 700
	text-transform: uppercase

.tools-export-format-option
	display: grid
	grid-template-columns: 16px minmax(0, 1fr)
	align-items: start
	gap: 8px
	width: 100%
	color: var(--text)
	font-size: .74rem
	cursor: pointer

	input
		width: 16px
		height: 16px
		accent-color: var(--accent)

	small
		grid-column: 2

	&.is-disabled
		color: var(--text-muted)
		cursor: not-allowed

		input
			cursor: not-allowed

.tools-export-package-info
	display: flex
	flex-direction: column
	gap: 6px
	padding: 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)

	&[hidden]
		display: none

.package-usage-section
	display: flex
	flex-direction: column
	gap: 6px
	padding: 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)

	&[hidden]
		display: none

.package-usage-list
	display: flex
	max-height: 320px
	flex-direction: column
	gap: 6px
	overflow: auto

.package-usage-row
	display: grid
	grid-template-columns: minmax(0, 1fr) auto
	gap: 8px
	align-items: start
	padding: 7px 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-1)

.package-usage-text
	display: flex
	min-width: 0
	flex-direction: column
	gap: 2px

	strong
		font-size: .74rem
		line-height: 1.3
		overflow-wrap: anywhere

	small
		color: var(--text-muted)
		font-size: .65rem
		line-height: 1.3
		overflow-wrap: anywhere

.package-usage-actions
	display: flex
	flex-direction: column
	gap: 5px

.package-usage-version-group
	padding: 7px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)

	summary
		cursor: pointer
		list-style-position: inside

	.package-usage-row
		margin-top: 6px

	h3
		display: inline
		margin: 0
		color: var(--accent)
		font-size: .74rem

	summary > small
		float: right
		margin-left: 8px
		color: var(--text-muted)
		font-size: .65rem

.tools-export-package-header
	display: flex
	align-items: center
	justify-content: space-between
	gap: 8px
	min-width: 0

.package-list-label
	min-width: 0
	color: var(--accent)
	font-size: .74rem
	text-transform: uppercase

.package-list-content
	color: var(--text)
	font-family: Cascadia Code NF, Consolas, monospace
	font-size: .7rem
	line-height: 1.35
	overflow-wrap: anywhere

.tools-progress
	display: flex
	flex-direction: column
	gap: 6px
	padding: 8px
	border: 1px solid var(--border)
	border-radius: 6px
	background: var(--surface-0)

.tools-progress-meta
	display: flex
	align-items: center
	justify-content: space-between
	gap: 10px
	color: var(--text-muted)
	font-size: .72rem

	span:first-child
		min-width: 0
		overflow: hidden
		text-overflow: ellipsis
		white-space: nowrap

.tools-progress-track
	height: 8px
	overflow: hidden
	border: 1px solid var(--border-strong)
	border-radius: 999px
	background: var(--surface-1)

.tools-progress-fill
	display: block
	width: 0
	height: 100%
	background: var(--accent)
	transition: width .16s ease

.tools-modal-backdrop
	position: fixed
	inset: 0
	z-index: 1000
	display: flex
	align-items: center
	justify-content: center
	padding: 14px
	background: rgba(0, 0, 0, .72)

.tools-modal
	display: flex
	width: min(100%, 420px)
	max-height: min(82vh, 620px)
	flex-direction: column
	gap: 10px
	padding: 14px
	color: var(--text)
	background: var(--surface-2)
	border: 1px solid var(--border-strong)
	border-radius: 8px
	box-shadow: 0 16px 44px rgba(0, 0, 0, .55)

	h2
		margin: 0
		color: var(--accent)
		font-size: .88rem
		text-transform: uppercase

	p
		margin: 0
		color: var(--text)
		font-size: .76rem
		line-height: 1.35

.tools-finish-log
	display: flex
	min-height: 70px
	max-height: 300px
	flex-direction: column
	gap: 6px
	overflow: auto

.tools-finish-line,
.tools-finish-empty
	margin: 0
	padding: 7px 8px
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border)
	border-radius: 6px
	font-size: .7rem
	line-height: 1.32
	overflow-wrap: anywhere

.tools-finish-warn
	border-color: var(--accent)

.tools-finish-error
	border-color: #A33A3A

.tools-results
	margin: 0
	padding: 8px
	color: var(--text)
	background: var(--surface-0)
	border: 1px solid var(--border)
	border-radius: 6px
	font-family: Cascadia Code NF, Consolas, monospace
	font-size: .7rem
	line-height: 1.35
	white-space: pre-wrap
	overflow-wrap: anywhere
	max-height: 260px
	overflow: auto

.tools-json-area
	min-height: 320px

#status
	min-height: 18px
	margin: 0
	color: var(--accent)
	font-size: .76rem

	&[data-severity='error']
		color: #FF8A8A

	&[data-severity='warn']
		color: var(--accent)
